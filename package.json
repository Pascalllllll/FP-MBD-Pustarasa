{
  "name": "pustarasa",
  "private": true,
  "version": "1.0.0",
  "description": "PustaRasa — Perpustakaan + Kantin. Orkestrasi setup & dev untuk backend (Express) dan frontend (Vite).",
  "scripts": {
    "setup": "node scripts/setup.js",
    "db:setup": "node scripts/db-setup.js",
    "db:reset": "node scripts/db-setup.js --force",
    "seed:accounts": "npm --prefix backend run seed:accounts",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm --prefix backend run dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "build": "npm --prefix frontend run build"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
